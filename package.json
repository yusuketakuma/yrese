{
  "name": "yrese",
  "version": "0.0.1",
  "private": true,
  "description": "調剤用レセプトコンピューター MVP — Cloud Core + Pharmacy Edge Node",
  "engines": {
    "node": ">=24",
    "pnpm": "11.13.1"
  },
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:calculation-purity": "node scripts/check-calculation-purity.mjs",
    "check:deps": "node scripts/check-deps.mjs",
    "check:openapi": "tsx scripts/check-openapi.mjs",
    "check:sbom": "node scripts/check-sbom.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:ssot-index": "node scripts/check-ssot-index.mjs",
    "db:check": "pnpm --filter @yrese/api db:check",
    "db:migrate": "pnpm --filter @yrese/api db:migrate",
    "generate:openapi": "tsx scripts/generate-openapi.mjs",
    "test:scripts": "node scripts/check-scripts.mjs",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "lint": "pnpm -r --if-present lint",
    "build": "pnpm -r build",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "yaml": "^2.9.0"
  }
}
