{
  "name": "@yrese/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "API contracts single source of truth. Runtime schemas and inferred TypeScript response types.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./error": "./src/error.ts",
    "./health": "./src/health.ts",
    "./openapi": "./src/openapi.ts",
    "./patient-search": "./src/patient-search.ts",
    "./reception-queue": "./src/reception-queue.ts",
    "./whoami": "./src/whoami.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json --outDir dist"
  },
  "dependencies": {
    "@yrese/shared-kernel": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "zod-openapi": "^6.0.0"
  }
}
