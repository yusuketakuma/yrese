{
  "name": "@yrese/calculation",
  "version": "0.0.1",
  "private": true,
  "description": "算定エンジンの純粋関数骨格。点数値・算定ルールは実装せず、根拠trace配線のみを提供する。",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json --outDir dist"
  },
  "dependencies": {
    "@yrese/date-time": "workspace:*",
    "@yrese/money": "workspace:*",
    "@yrese/shared-kernel": "workspace:*",
    "@yrese/trace": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
